# Database (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=widle_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=widle_insure
DATABASE_URL=postgresql+asyncpg://widle_user:your_secure_password@localhost:5432/widle_insure

# Security
SECRET_KEY=your-super-secret-jwt-key-here-min-32-chars
API_KEY=your-api-key-for-service-to-service-calls

# CORS (adjust for your frontend URL)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# AI APIs (for Week 3)
ANTHROPIC_API_KEY=your-claude-api-key
OPENAI_API_KEY=your-gpt4-api-key  # Optional backup

# File Storage
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# Environment
DEBUG=False
